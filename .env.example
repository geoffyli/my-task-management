# Notion API key (required)
# Get from https://www.notion.so/my-integrations
NOTION_API_KEY=

# Server port (default: 3456)
PORT=3456

# SQLite database path (default: ./data/analytics.db)
DB_PATH=./data/analytics.db

# Public webhook URL (for reference in admin UI)
# Local: use ngrok URL (e.g., https://xxxxx.ngrok-free.app/api/webhooks/notion)
# Production: use Railway URL (e.g., https://your-app.railway.app/api/webhooks/notion)
NOTION_WEBHOOK_URL=

# Authentication token (required in production)
# Generate with: openssl rand -hex 32
TOKEN=
